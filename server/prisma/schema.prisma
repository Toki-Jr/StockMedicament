datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model user {
  id        Int      @id @default(autoincrement())
  nom       String
  prenom    String
  email     String   @unique
  password  String
  role      String   @default("user")
  photo     String?
  fontSize  Int      @default(14)
  approuve  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  commandes commande[]
  alertes   alerte[]
  historiques historique[]
}

model medicament {
  id_medoc                Int        @id @default(autoincrement())
  code_cip                String     @unique
  nom                     String
  forme                   String
  dosage                  Decimal
  prix_unitaire           Int
  seuil_alerte_qte        Int
  seuil_alerte_peremption Int
  lots                    lot[]
  lignes                  lignecommande[]
  alertes                 alerte[]
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
}

model lot {
  id_lot           Int              @id @default(autoincrement())
  numero_lot       String
  date_fabrication DateTime
  date_expiration  DateTime
  quantite_entre   Int
  quantite_sortie  Int
  id_medoc         Int
  medicament       medicament       @relation(fields: [id_medoc], references: [id_medoc])
  mouvements       mouvementstock[]
}

model mouvementstock {
  id_mvt       Int      @id @default(autoincrement())
  type_mvt     String
  quantite_mvt Int
  date_mvt     DateTime @default(now())
  motif        String
  id_lot       Int
  lot          lot      @relation(fields: [id_lot], references: [id_lot])
}

model commande {
  id_commande   Int        @id @default(autoincrement())
  date_commande DateTime   @default(now())
  statut        String     @default("brouillon")
  motif_rejet   String?
  id_user       Int
  lignes        lignecommande[]
  user          user       @relation(fields: [id_user], references: [id])
}

model alerte {
  id_alerte   Int        @id @default(autoincrement())
  type_alerte String
  message     String
  lu          Boolean    @default(false)
  role_cible  String?
  createdAt   DateTime   @default(now())
  id_user     Int?
  user        user?      @relation(fields: [id_user], references: [id])
  @@index([id_user])
  id_medoc    Int?
  medicament  medicament? @relation(fields: [id_medoc], references: [id_medoc])
}

model historique {
  id_historique Int      @id @default(autoincrement())
  action        String   
  description   String
  id_user       Int
  user          user     @relation(fields: [id_user], references: [id])
  createdAt     DateTime @default(now())
}

model lignecommande {
  id_ligne    Int @id @default(autoincrement())
  quantite    Int
  id_commande Int
  id_medoc    Int
  commande    commande @relation(fields: [id_commande], references: [id_commande], onDelete: Cascade)
  medicament  medicament @relation(fields: [id_medoc], references: [id_medoc])
}